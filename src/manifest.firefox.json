{
  "manifest_version": 3,
  "name": "Bring Back Live Seek",
  "short_name": "BBLS",
  "version": "1.0.1",
  "description": "Restores seek buttons (rewind / fast-forward) on Hotstar live streams with a glassmorphism UI.",
  "icons": {
    "16": "/icons/icon-16.png",
    "32": "/icons/icon-32.png",
    "48": "/icons/icon-48.png",
    "128": "/icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "/icons/icon-16.png",
      "32": "/icons/icon-32.png"
    },
    "default_title": "Bring Back Live Seek"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.hotstar.com/*/video/live/watch*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bbls@ramvignesh.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
